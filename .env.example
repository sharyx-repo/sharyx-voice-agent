# Sharyx Voice Agent - Environment Variables

# OpenAI API Key (Required for OpenAILLM)
OPENAI_API_KEY=your_openai_api_key_here

# Deepgram API Key (Required for DeepgramSTT)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ElevenLabs API Key (Required for ElevenLabsTTS)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Telephony Providers
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
PLIVO_AUTH_ID=your_plivo_id
PLIVO_AUTH_TOKEN=your_plivo_token

# Redis Configuration (Required for persistent memory)
REDIS_URL=redis://localhost:6379

# Public URL (Required for webhook signature verification)
# Example: https://myapp.ngrok-free.app or https://api.sharyx.ai
SHARYX_PUBLIC_URL=your_public_url_here

# Port for local development
PORT=3000
